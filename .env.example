# ─── Required ─────────────────────────────────────────────────────────────────

# Groq API (free at console.groq.com — for AI-generated summary)
GROQ_API_KEY=gsk_your_groq_key_here

# MongoDB (MongoDB Atlas free tier works — for storing leads)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/spendlens

# ─── Optional (not required for core features) ────────────────────────────────

# Supabase (only if you prefer Supabase over MongoDB)
# NEXT_PUBLIC_SUPABASE_URL=https://yourproject.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
